{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "eas-build-pre-install": "npm install -g pnpm@10.33.2",
    "preinstall": "node -e \"const fs=require('fs'); ['package-lock.json','yarn.lock'].forEach(f => { if(fs.existsSync(f)) fs.unlinkSync(f); })\"",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./apps/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
