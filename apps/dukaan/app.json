{
  "expo": {
    "jsEngine": "hermes",
    "name": "SaleSync - Digital Register",
    "slug": "workspace",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.jpg",
    "scheme": "salesync",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#FFFBF5"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.chromastone07.salesync",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.jpg"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://salesync.app/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow SaleSync to access your camera to scan barcodes."
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3940256099942544~3347511713",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ],
      "expo-build-properties",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "origin": "https://salesync.app/"
      },
      "eas": {
        "projectId": "0a51c30e-d9ef-44f0-bb7c-54295a07cfb5"
      }
    },
    "owner": "chromastone07"
  }
}
